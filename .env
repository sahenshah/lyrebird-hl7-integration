# ===============================
# HL7 Listener (TCP/MLLP)
# ===============================
HL7_HOST=0.0.0.0
HL7_PORT=2575

# ===============================
# Listener Processing Limits
# ===============================
BUFFER_SIZE_LIMIT=1048576
MAX_FRAMING_ERRORS=5
MAX_BUFFER_SIZE=1048576
MAX_MESSAGE_SIZE=1048576

# ===============================
# Retry / Idempotency
# ===============================
MAX_RETRIES=3
RETRY_BACKOFF_BASE=0.5
IDEMPOTENCY_CACHE_SIZE=1000
IDEMPOTENCY_EXPIRY_HOURS=24

# ===============================
# FastAPI Backend Bind Settings
# ===============================
API_BIND_HOST=0.0.0.0
API_BIND_PORT=8000

# ===============================
# FastAPI TLS (HTTPS)
# ===============================
API_SSL_CERTFILE=cert.pem
API_SSL_KEYFILE=key.pem

# ===============================
# Listener -> FastAPI Outbound URL
# ===============================
# API endpoint for listener to forward HL7 messages
# Use 'http://backend:8000/api/v1/messages' for Docker Compose
# Use 'http://localhost:8000/api/v1/messages' for local/manual runs
API_URL=http://localhost:8000/api/v1/messages
#API_URL=http://backend:8000/api/v1/messages

# ===============================
# FastAPI Outbound URL -> Downstream Stub API
# ===============================
DOWNSTREAM_CA_BUNDLE=/certs/stub.crt
# Stub API endpoint for FastAPI to forward processed HL7 messages to (downstream) 
# Use 'https://host.docker.internal:9000/receive' for Docker Compose
# Use 'https://localhost:9000/receive' for local/manual runs
DOWNSTREAM_API_URL=https://localhost:9000/receive
#DOWNSTREAM_API_URL=https://host.docker.internal:9000/receive