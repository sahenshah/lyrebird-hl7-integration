{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json_app": {
      "class": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(asctime)s %(levelname)s %(name)s %(message)s"
    },
    "json_uvicorn_default": {
      "class": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(asctime)s %(levelname)s %(name)s %(message)s"
    },
    "json_uvicorn_access": {
      "class": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(asctime)s %(levelname)s %(name)s %(client_addr)s %(request_line)s %(status_code)s"
    }
  },
  "handlers": {
    "app": {
      "class": "logging.StreamHandler",
      "formatter": "json_app",
      "stream": "ext://sys.stdout"
    },
    "uvicorn_default": {
      "class": "logging.StreamHandler",
      "formatter": "json_uvicorn_default",
      "stream": "ext://sys.stdout"
    },
    "uvicorn_access": {
      "class": "logging.StreamHandler",
      "formatter": "json_uvicorn_access",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["uvicorn_default"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["uvicorn_default"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["uvicorn_access"],
      "level": "INFO",
      "propagate": false
    },
    "app": {
      "handlers": ["app"],
      "level": "INFO",
      "propagate": false
    },
    "hl7_listener": {
      "handlers": ["app"],
      "level": "INFO",
      "propagate": false
    }
  },
  "root": {
    "handlers": ["app"],
    "level": "WARNING"
  }
}